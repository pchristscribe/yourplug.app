  "pnpm": {
    "overrides": {
      "shell-quote": ">=1.8.4"
    }
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
