# Supabase Configuration
# Local dev: run `supabase start` then paste the anon key and service_role key it prints.
# Production: use your hosted project URL + keys from the Supabase dashboard.
NUXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NUXT_PUBLIC_SUPABASE_KEY=<paste-anon-key-from-supabase-start>
# Admin-only service role key (never expose to client)
SUPABASE_SECRET_KEY=<paste-service-role-key-from-supabase-start>

# Public site URL — used for canonical links, OG tags, and sitemap.xml entries.
# Set to the production domain (Railway); localhost for dev.
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Database Configuration (local development - Supabase is used in production)
POSTGRES_USER=yourplug
POSTGRES_PASSWORD=dev_password_change_in_production
POSTGRES_DB=yourplug_db
POSTGRES_PORT=5432

# Database URL for the Fastify backend (postgres-js). Production: use the Supabase pooler URL with ?sslmode=require
DATABASE_URL="postgresql://yourplug:dev_password_change_in_production@localhost:5432/yourplug_db"

# Redis Configuration
REDIS_PASSWORD=dev_redis_password
REDIS_PORT=6379
REDIS_URL="redis://:dev_redis_password@localhost:6379"

# Application Configuration
NODE_ENV=development
PORT=3001

# Backend API URL (admin frontend connects here for WebAuthn)
API_BASE_URL=http://localhost:3001

# WebAuthn / Admin Authentication (required for production)
# SESSION_SECRET=generate-a-64-char-random-string-here
# RP_ID=admin.yourdomain.com
# ADMIN_URL=https://admin.yourdomain.com

# Consignment Marketplace (Plug Market)
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
MARKETPLACE_URL=http://localhost:3003

# Affiliate API Keys (to be added when available)
# DHGATE_API_KEY=
# ALIEXPRESS_API_KEY=
# AMAZON_ASSOCIATES_TAG=
# WISH_API_KEY=

# Dub.co Link Tracking (to be added when available)
# DUB_API_KEY=
# DUB_WORKSPACE_ID=

# Sentry Error Monitoring & Performance Tracking
# Each service has its own Sentry project and DSN. Set these in each workspace's .env:
#   backend/.env        → SENTRY_DSN=<backend-project-dsn>
#   frontend/.env       → SENTRY_DSN=<frontend-project-dsn> + NUXT_PUBLIC_SENTRY_DSN=<same> + VITE_SENTRY_DSN=<same>
#   admin-frontend/.env → SENTRY_DSN=<admin-project-dsn>   + NUXT_PUBLIC_SENTRY_DSN=<same> + VITE_SENTRY_DSN=<same>
#   marketplace/.env    → SENTRY_DSN=<marketplace-project-dsn> + NUXT_PUBLIC_SENTRY_DSN=<same> + VITE_SENTRY_DSN=<same>
# The three Nuxt apps need BOTH NUXT_PUBLIC_SENTRY_DSN and VITE_SENTRY_DSN set to the same
# value — they're read in different places:
#   - NUXT_PUBLIC_SENTRY_DSN reaches Vue components/composables via useRuntimeConfig().public
#   - VITE_SENTRY_DSN reaches sentry.client.config.ts via import.meta.env, which is the ONLY
#     mechanism that works there — that file loads outside the normal Nuxt app/component
#     lifecycle, so useRuntimeConfig() isn't safe to call and bare process.env.NUXT_PUBLIC_*
#     is never populated in the browser bundle at all (no `process.env` injection happens
#     client-side beyond the few values Vite statically replaces, like NODE_ENV).
#   Forgetting VITE_SENTRY_DSN means Sentry.init() runs with dsn=undefined client-side —
#   it fails silently (no error, no client registered, no events ever sent from the browser).
# In Railway, set all of these as per-service environment variables.
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# NUXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# SENTRY_ENVIRONMENT=production               # server-side environment tag (backend + Nuxt SSR); falls back to NODE_ENV
# NUXT_PUBLIC_SENTRY_ENVIRONMENT=production    # exposed to Vue components via useRuntimeConfig().public; not read by sentry.client.config.ts
# VITE_SENTRY_ENVIRONMENT=production           # client-side environment tag actually used by sentry.client.config.ts; falls back to NODE_ENV
# SENTRY_RELEASE=1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions for performance monitoring (0.0 to 1.0)
# SENTRY_PROFILES_SAMPLE_RATE=0.1  # 10% for profiling (0.0 to 1.0, backend only)
# SENTRY_AUTH_TOKEN=  # Sentry auth token for source-map upload during Nuxt builds (frontend/admin-frontend/marketplace); readable stack traces in production require this
# SENTRY_ORG=yourplug  # for reference — org/project are currently hardcoded per service in each nuxt.config.ts's `sentry:` block
# SENTRY_PROJECT=  # project slug for the service in question, e.g. frontend-nuxt / admin-frontend-nuxt / marketplace-nuxt

# Supabase CLI (for migrations)
SUPABASE_ACCESS_TOKEN=sbp_your-access-token
SUPABASE_PROJECT_REF=oqkfirmzkdfkfcvzqipo
