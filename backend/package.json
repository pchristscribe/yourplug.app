{
  "name": "yourplug-backend",
  "version": "1.0.0",
  "description": "Backend API for yourplug affiliate marketing platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --import ./src/instrument.js --watch src/index.js",
    "start": "node --import ./src/instrument.js src/index.js",
    "worker": "node --import ./src/instrument.js src/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "affiliate",
    "marketing",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/session": "^11.1.1",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcryptjs": "^3.0.3",
    "connect-redis": "^9.0.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.8"
  }
}
