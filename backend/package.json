{
  "name": "yourplug-backend",
  "version": "1.0.0",
  "description": "Backend API for yourplug affiliate marketing platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --import ./src/instrument.js --watch src/index.js",
    "start": "node --import ./src/instrument.js src/index.js",
    "worker": "node --import ./src/instrument.js src/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "affiliate",
    "marketing",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@dotenvx/dotenvx": "^2.0.0",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/session": "^11.1.2",
    "@sentry/node": "^10.66.0",
    "@sentry/profiling-node": "^10.66.0"
    "@simplewebauthn/server": "^13.3.2",
    "@supabase/supabase-js": "^2.110.7",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "exif-reader": "^2.0.3",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.8"
  }
}
