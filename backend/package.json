{
  "name": "yourplug-backend",
  "version": "1.0.0",
  "description": "Backend API for yourplug affiliate marketing platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --import ./src/instrument.js --watch src/index.js",
    "start": "node --import ./src/instrument.js src/index.js",
    "worker": "node --import ./src/instrument.js src/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "affiliate",
    "marketing",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@dotenvx/dotenvx": "^2.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/session": "^11.1.1",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "@simplewebauthn/server": "^13.3.2",
    "@supabase/supabase-js": "^2.110.0",
    "bcryptjs": "^3.0.3",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.4.2",
    "exif-reader": "^2.0.3",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.6.0",
